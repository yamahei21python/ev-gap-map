{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/(lp|LP)", "destination": "/public/lp/index.html" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/data/(.*)", "destination": "/public/data/$1" },
    { "source": "/style.css", "destination": "/public/style.css" },
    { "source": "/landing_hero.png", "destination": "/public/landing_hero.png" }
  ]
}
